---
import GoBackIcon from '@/assets/icons/go-back.svg'
---

<button
  id="back-button"
  class="post-back-button"
  type="button"
  aria-label="返回文章列表"
>
  <GoBackIcon
    aria-hidden="true"
    fill="currentColor"
  />
</button>

<!-- Go Back Script >>>>>>>>>>>>>>>>>>>>>>>>>>>>>>>>>>>>>>>>>>>>>>>>>>>>>>>>>>>>>>>>>>>>>>>>>>>>>>>>>>>>>>>>>>>>>>>>>>>>>>>>>>>>>>>>>>>>>>>>>>>>> -->
<script>
function handleBackButtonClick(e: MouseEvent) {
  if (!(e.target instanceof Element)) {
    return
  }

  if (!e.target.closest('#back-button')) {
    return
  }

  // Navigate back if history exists
  if (window.history.length > 1) {
    window.history.back()
    return
  }

  // Fallback to homepage
  const siteTitleLink = document.getElementById('site-title-link')
  if (siteTitleLink) {
    siteTitleLink.click()
  }
}

document.addEventListener('click', handleBackButtonClick)
</script>
