---
interface Props {
  label: string
  target: string
  targetLabel: string
}

const { label, target, targetLabel } = Astro.props
---

<section
  class="countdown-shell c-primary"
  data-countdown
  data-target={target}
  aria-label={`${label}，目标时间：${targetLabel}`}
>
  <div class="countdown-content">
    <p class="countdown-title font-unified">{label}</p>

    <div class="countdown-grid" aria-hidden="true">
      <div class="countdown-unit countdown-unit-days">
        <span class="countdown-number font-unified" data-countdown-part="days">0000</span>
        <span class="countdown-unit-label">天</span>
      </div>
      <div class="countdown-unit">
        <span class="countdown-number font-unified" data-countdown-part="hours">00</span>
        <span class="countdown-unit-label">时</span>
      </div>
      <div class="countdown-unit">
        <span class="countdown-number font-unified" data-countdown-part="minutes">00</span>
        <span class="countdown-unit-label">分</span>
      </div>
      <div class="countdown-unit">
        <span class="countdown-number font-unified" data-countdown-part="seconds">00</span>
        <span class="countdown-unit-label">秒</span>
      </div>
    </div>

    <p class="countdown-expired" data-countdown-expired hidden>时间到了。</p>
  </div>
</section>

<script>
  function initializeCountdown(root: HTMLElement) {
    if (root.dataset.initialized === 'true')
      return

    const targetTime = Date.parse(root.dataset.target ?? '')
    if (Number.isNaN(targetTime))
      return

    root.dataset.initialized = 'true'

    const days = root.querySelector<HTMLElement>('[data-countdown-part="days"]')
    const hours = root.querySelector<HTMLElement>('[data-countdown-part="hours"]')
    const minutes = root.querySelector<HTMLElement>('[data-countdown-part="minutes"]')
    const seconds = root.querySelector<HTMLElement>('[data-countdown-part="seconds"]')
    const expired = root.querySelector<HTMLElement>('[data-countdown-expired]')

    if (!days || !hours || !minutes || !seconds || !expired)
      return

    let timer: number | undefined

    const update = () => {
      const remaining = Math.max(0, targetTime - Date.now())
      const totalSeconds = Math.floor(remaining / 1000)

      days.textContent = String(Math.floor(totalSeconds / 86400))
      hours.textContent = String(Math.floor((totalSeconds % 86400) / 3600)).padStart(2, '0')
      minutes.textContent = String(Math.floor((totalSeconds % 3600) / 60)).padStart(2, '0')
      seconds.textContent = String(totalSeconds % 60).padStart(2, '0')

      if (remaining > 0)
        return

      expired.hidden = false
      if (timer !== undefined)
        window.clearInterval(timer)
    }

    update()
    if (targetTime > Date.now())
      timer = window.setInterval(update, 1000)

    document.addEventListener('astro:before-swap', () => {
      if (timer !== undefined)
        window.clearInterval(timer)
    }, { once: true })
  }

  function initializeCountdowns() {
    document
      .querySelectorAll<HTMLElement>('[data-countdown]')
      .forEach(initializeCountdown)
  }

  initializeCountdowns()
  document.addEventListener('astro:page-load', initializeCountdowns)
</script>

<style>
  .countdown-shell {
    margin-bottom: 3rem;
    border: 1px solid oklch(var(--un-preset-theme-colors-secondary) / 0.12);
    border-radius: 0.45rem;
    background: oklch(var(--un-preset-theme-colors-secondary) / 0.045);
  }

  .countdown-content {
    padding: 1.25rem 1rem;
  }

  .countdown-title {
    margin-bottom: 1rem;
    font-size: 1.2rem;
    font-weight: 500;
    line-height: 1.35;
    letter-spacing: 0.015em;
  }

  .countdown-grid {
    display: grid;
    grid-template-columns: repeat(4, minmax(0, 1fr));
  }

  .countdown-unit {
    position: relative;
    display: flex;
    min-height: 3.5rem;
    min-width: 0;
    flex-direction: column;
    align-items: center;
    justify-content: center;
    gap: 0.55rem;
    padding: 0.25rem;
    text-align: center;
  }

  .countdown-unit:not(:last-child) {
    border-right: 1px solid oklch(var(--un-preset-theme-colors-secondary) / 0.16);
  }

  .countdown-number {
    display: block;
    overflow: hidden;
    font-size: clamp(1.45rem, 7vw, 1.85rem);
    font-variant-numeric: tabular-nums;
    font-weight: 400;
    line-height: 1;
    white-space: nowrap;
  }

  .countdown-unit-days .countdown-number {
    font-size: clamp(1.45rem, 7vw, 1.85rem);
  }

  .countdown-unit-label {
    display: block;
    font-size: 0.8rem;
    letter-spacing: 0.04em;
    opacity: 0.72;
  }

  .countdown-expired {
    margin-top: 1rem;
    font-weight: 500;
  }

  @media (min-width: 1024px) {
    .countdown-shell {
      margin-bottom: 6.7rem;
    }

    .countdown-content {
      display: grid;
      grid-template-columns: minmax(10rem, 0.8fr) minmax(27rem, 2.2fr);
      align-items: center;
      padding: 1.2rem 1.5rem;
    }

    .countdown-title {
      margin: 0;
      font-size: 1.1rem;
    }

    .countdown-unit {
      min-height: 2.75rem;
      flex-direction: row;
      justify-content: flex-start;
      border-right: 0 !important;
      padding: 0.25rem 0.75rem;
      text-align: left;
    }

    .countdown-unit:first-child {
      padding-left: 0;
    }

    .countdown-number,
    .countdown-unit-days .countdown-number {
      font-size: 1.45rem;
    }

    .countdown-unit-label {
      font-size: 0.75rem;
    }
  }
</style>
