---
interface Props {
  label: string
  target: string
  targetLabel: string
}

const { label, target, targetLabel } = Astro.props
---

<section
  class="countdown-shell c-primary"
  data-countdown
  data-target={target}
  aria-label={`${label}，目标时间：${targetLabel}`}
>
  <div class="countdown-content">
    <p class="countdown-title font-unified">{label}</p>

    <div class="countdown-grid" aria-hidden="true">
      <div class="countdown-unit countdown-unit-days">
        <span class="countdown-number font-unified" data-countdown-part="days">0000</span>
        <span class="countdown-unit-label">天</span>
      </div>
      <div class="countdown-unit">
        <span class="countdown-number font-unified" data-countdown-part="hours">00</span>
        <span class="countdown-unit-label">时</span>
      </div>
      <div class="countdown-unit">
        <span class="countdown-number font-unified" data-countdown-part="minutes">00</span>
        <span class="countdown-unit-label">分</span>
      </div>
      <div class="countdown-unit">
        <span class="countdown-number font-unified" data-countdown-part="seconds">00</span>
        <span class="countdown-unit-label">秒</span>
      </div>
    </div>

    <p class="countdown-expired" data-countdown-expired hidden>时间到了。</p>
  </div>
</section>

<script>
  function initializeCountdown(root: HTMLElement) {
    if (root.dataset.initialized === 'true')
      return

    const targetTime = Date.parse(root.dataset.target ?? '')
    if (Number.isNaN(targetTime))
      return

    root.dataset.initialized = 'true'

    const days = root.querySelector<HTMLElement>('[data-countdown-part="days"]')
    const hours = root.querySelector<HTMLElement>('[data-countdown-part="hours"]')
    const minutes = root.querySelector<HTMLElement>('[data-countdown-part="minutes"]')
    const seconds = root.querySelector<HTMLElement>('[data-countdown-part="seconds"]')
    const expired = root.querySelector<HTMLElement>('[data-countdown-expired]')

    if (!days || !hours || !minutes || !seconds || !expired)
      return

    let timer: number | undefined

    const update = () => {
      const remaining = Math.max(0, targetTime - Date.now())
      const totalSeconds = Math.floor(remaining / 1000)

      days.textContent = String(Math.floor(totalSeconds / 86400))
      hours.textContent = String(Math.floor((totalSeconds % 86400) / 3600)).padStart(2, '0')
      minutes.textContent = String(Math.floor((totalSeconds % 3600) / 60)).padStart(2, '0')
      seconds.textContent = String(totalSeconds % 60).padStart(2, '0')

      if (remaining > 0)
        return

      expired.hidden = false
      if (timer !== undefined)
        window.clearInterval(timer)
    }

    update()
    if (targetTime > Date.now())
      timer = window.setInterval(update, 1000)

    document.addEventListener('astro:before-swap', () => {
      if (timer !== undefined)
        window.clearInterval(timer)
    }, { once: true })
  }

  function initializeCountdowns() {
    document
      .querySelectorAll<HTMLElement>('[data-countdown]')
      .forEach(initializeCountdown)
  }

  initializeCountdowns()
  document.addEventListener('astro:page-load', initializeCountdowns)
</script>

<style>
  .countdown-shell {
    margin-bottom: 2rem;
    overflow: hidden;
    border: 1px solid var(--editorial-rule);
    border-radius: 0.2rem;
    background: var(--editorial-surface);
  }

  .countdown-content {
    padding: 0.72rem 0.7rem 0.75rem;
  }

  .countdown-title {
    margin: 0 0 0.55rem;
    color: var(--editorial-accent-strong);
    font-size: 0.92rem;
    font-weight: 500;
    line-height: 1.2;
    letter-spacing: 0.035em;
    text-align: center;
  }

  .countdown-grid {
    display: grid;
    grid-template-columns: repeat(4, minmax(0, 1fr));
  }

  .countdown-unit {
    position: relative;
    display: flex;
    min-width: 0;
    min-height: 1.8rem;
    align-items: baseline;
    justify-content: center;
    gap: 0.16rem;
    padding: 0.1rem 0.16rem;
    text-align: center;
  }

  .countdown-unit:not(:last-child) {
    border-right: 1px solid var(--editorial-rule);
  }

  .countdown-number {
    display: block;
    min-width: 0;
    overflow: hidden;
    color: oklch(var(--un-preset-theme-colors-primary));
    font-size: 0.92rem;
    font-variant-numeric: tabular-nums;
    font-weight: 400;
    line-height: 1;
    white-space: nowrap;
  }

  .countdown-unit-days .countdown-number {
    font-size: 0.92rem;
  }

  .countdown-unit-label {
    display: block;
    flex: none;
    color: oklch(var(--un-preset-theme-colors-secondary));
    font-size: 0.58rem;
    letter-spacing: 0.015em;
    opacity: 0.76;
  }

  .countdown-expired {
    margin-top: 0.5rem;
    font-size: 0.7rem;
    font-weight: 500;
    text-align: center;
  }

  @media (max-width: 359px) {
    .countdown-content {
      padding-right: 0.45rem;
      padding-left: 0.45rem;
    }

    .countdown-title,
    .countdown-number,
    .countdown-unit-days .countdown-number {
      font-size: 0.82rem;
    }

    .countdown-unit-label {
      font-size: 0.54rem;
    }
  }

  @media (min-width: 768px) {
    .countdown-shell {
      margin-bottom: 2.85rem;
    }

    .countdown-content {
      padding: 1rem 2rem;
    }

    .countdown-title {
      margin: 0 0 0.7rem;
      font-size: 1.2rem;
      line-height: 1.1;
      letter-spacing: 0.03em;
    }

    .countdown-grid {
      align-items: baseline;
    }

    .countdown-unit {
      min-width: 0;
      min-height: 2rem;
      gap: 0.28rem;
      padding: 0.1rem 1rem;
    }

    .countdown-number,
    .countdown-unit-days .countdown-number {
      font-size: 1.2rem;
    }

    .countdown-unit-label {
      font-size: 0.7rem;
      line-height: 1;
    }
  }

  @media (min-width: 1024px) {
    .countdown-content {
      display: grid;
      grid-template-columns: minmax(21.5rem, 1.25fr) minmax(27rem, 2.75fr);
      align-items: baseline;
      min-height: 0;
      padding: 1rem 2.25rem;
    }

    .countdown-title {
      align-self: baseline;
      margin: 0;
      font-size: 1.35rem;
      line-height: 1;
      letter-spacing: 0.02em;
      text-align: left;
      white-space: nowrap;
    }

    .countdown-unit {
      min-height: 0;
      align-self: baseline;
      padding-right: 0.85rem;
      padding-left: 0.85rem;
    }

    .countdown-number,
    .countdown-unit-days .countdown-number {
      font-size: 1.35rem;
    }
  }

  @media (min-width: 1100px) {
    .countdown-content {
      grid-template-columns: minmax(21.5rem, 1.25fr) minmax(27rem, 2.75fr);
      padding: 1.05rem 2.8rem;
    }

    .countdown-title {
      font-size: 1.4rem;
    }

    .countdown-number,
    .countdown-unit-days .countdown-number {
      font-size: 1.4rem;
    }
  }
</style>
