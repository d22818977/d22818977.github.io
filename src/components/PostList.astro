---
import type { Language } from '@/i18n/config'
import type { Post } from '@/types'
import GoBackIcon from '@/assets/icons/go-back.svg'
import PinIcon from '@/assets/icons/pin-icon.svg'
import PostDate from '@/components/PostDate.astro'
import { getPostPath } from '@/i18n/path'
import { getPostDescription } from '@/utils/description'
import { isHomePage } from '@/utils/page'

export interface Props {
  posts: Post[]
  lang: Language
  pinned?: boolean
}

const { posts, lang, pinned = false } = Astro.props
const isHome = isHomePage(Astro.url.pathname)
---

{isHome
  ? (
  <ul class="home-post-list">
    {posts.map((post) => {
      const slug = post.data.abbrlink || post.id

      return (
        <li class="home-post-item">
          <a
            class="home-post-link"
            href={getPostPath(slug, lang)}
            aria-label={`阅读《${post.data.title}》`}
          >
            <div
              class="home-post-date font-time"
              transition:name={`time-${slug}${lang ? `-${lang}` : ''}`}
              data-disable-theme-toggle-transition
            >
              <PostDate
                date={post.data.published}
                minutes={post.remarkPluginFrontmatter.minutes}
                showReadingTime={false}
              />
            </div>

            <span class="home-post-timeline" aria-hidden="true" />

            <div class="home-post-copy">
              <h3 class="home-post-heading c-primary">
                <span
                  class="home-post-title cjk:tracking-wide"
                  transition:name={`post-${slug}${lang ? `-${lang}` : ''}`}
                  data-disable-theme-toggle-transition
                >
                  {post.data.title}
                </span>
                {pinned && (
                  <PinIcon
                    aria-hidden="true"
                    class="ml-0.25em inline-block aspect-square w-0.98em translate-y--0.1em"
                    fill="currentColor"
                  />
                )}
              </h3>

              <p class="home-post-description heti">
                {getPostDescription(post, 'list')}
              </p>
            </div>

            <span class="home-post-arrow" aria-hidden="true">
              <GoBackIcon fill="currentColor" />
            </span>
          </a>
        </li>
      )
    })}
  </ul>
  )
  : (
  <ul>
    {posts.map((post) => {
      const slug = post.data.abbrlink || post.id

      return (
        <li class="mb-5.5">
          <h3 class="inline transition-colors hover:c-primary">
            <a
              class="cjk:tracking-wide"
              href={getPostPath(slug, lang)}
              transition:name={`post-${slug}${lang ? `-${lang}` : ''}`}
              data-disable-theme-toggle-transition
            >
              {post.data.title}
            </a>
            {pinned && (
              <PinIcon
                aria-hidden="true"
                class="ml-0.25em inline-block aspect-square w-0.98em translate-y--0.1em lg:(w-1.05em translate-y--0.15em)"
                fill="currentColor"
              />
            )}
          </h3>

          <div
            class="py-0.8 text-3.5 font-time lg:hidden"
            transition:name={`time-${slug}${lang ? `-${lang}` : ''}`}
            data-disable-theme-toggle-transition
          >
            <PostDate
              date={post.data.published}
              minutes={post.remarkPluginFrontmatter.minutes}
            />
          </div>

          <div class="hidden text-3.65 font-time lg:(ml-2.5 inline)">
            <PostDate
              date={post.data.published}
              minutes={post.remarkPluginFrontmatter.minutes}
            />
          </div>
        </li>
      )
    })}
  </ul>
  )}
