---
import { allLocales } from '@/config'
import { getLangRouteParam } from '@/i18n/lang'
import Layout from '@/layouts/Layout.astro'

export async function getStaticPaths() {
  return allLocales.map(lang => ({
    params: { lang: getLangRouteParam(lang) },
  }))
}

const pageTitle = 'Huawei OptiXstar B896-U6'
const pageDescription = '融合 FTTO 全光接入、Wi-Fi 7 无线覆盖与 NVR 视频存储的一体化网关。'
---

