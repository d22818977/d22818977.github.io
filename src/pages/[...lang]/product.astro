        <p>FOUR ROLES, ONE GATEWAY</p>
        <h2 id="capabilities-title">一台设备，四个角色。</h2>
      </div>

      <div class="feature-showcase" data-feature-showcase data-reveal>
        <div class="feature-tabs" role="tablist" aria-label="产品核心卖点">
          <button
            type="button"
            class="feature-tab is-active"
            role="tab"
            aria-selected="true"
            aria-controls="feature-detail"
