            data-feature-kind="fiber"
            data-index="01"
            data-label="全光接入"
            data-title="光纤延伸到业务现场"
            data-copy="以 FTTO 架构承载园区连接，减少中间有源节点和冗余铜缆，让网络部署更清爽，也为后续扩展预留更长生命周期。"
            data-image="/images/product/feature-fiber.webp"
            data-image-alt="光纤连接企业网络设备的特写"
          >
            <span>01</span>
            <strong>全光接入</strong>
            <small>Fiber to the Office</small>
          </button>
          <button
            type="button"
            class="feature-tab"
            role="tab"
            aria-selected="false"
            aria-controls="feature-detail"
            data-feature-tab
            data-feature-kind="wifi"
            data-index="02"
            data-label="无线覆盖"
            data-title="Wi-Fi 7 融入一体化网关"
            data-copy="无线接入能力直接融入融合网关，减少额外设备堆叠，为高密终端、办公协作和移动业务提供统一的无线入口。"
            data-image="/images/product/feature-wifi.webp"
            data-image-alt="具备连续无线覆盖的现代办公空间"
          >
            <span>02</span>
            <strong>无线覆盖</strong>
            <small>Wi-Fi 7 Ready</small>
          </button>
          <button
            type="button"
            class="feature-tab"
            role="tab"
            aria-selected="false"
            aria-controls="feature-detail"
            data-feature-tab
            data-feature-kind="video"
            data-index="03"
            data-label="视频存储"
            data-title="NVR 与本地存储直接融合"
            data-copy="视频录像、硬盘存储与网络接入共享同一设备形态，简化摄像机回传、录像留存与日常维护之间的链路。"
            data-image="/images/product/feature-video.webp"
            data-image-alt="视频安防监控摄像机与监控画面"
          >
            <span>03</span>
            <strong>视频存储</strong>
            <small>Integrated NVR</small>
          </button>
          <button
            type="button"
            class="feature-tab"
            role="tab"
            aria-selected="false"
            aria-controls="feature-detail"
            data-feature-tab
            data-feature-kind="storage"
            data-index="04"
            data-label="弹性容量"
            data-title="4T 与 8T 两种存储配置"
            data-copy="根据门店、办公室与小型园区的视频留存需求选择对应容量。部署规模更贴合实际，避免过度配置。"
            data-image="/images/product/feature-storage.webp"
            data-image-alt="企业本地存储硬盘与设备仓"
          >
            <span>04</span>
            <strong>弹性容量</strong>
            <small>4 TB / 8 TB</small>
          </button>
        </div>

        <div id="feature-detail" class="feature-detail" role="tabpanel" aria-live="polite">
          <div class="feature-media" data-feature-media data-active-feature="fiber">
            <img
              src="/images/product/feature-fiber.webp"
              width="1600"
              height="900"
              alt="光纤连接企业网络设备的特写"
              loading="lazy"
              data-feature-image
            />
            <div class="feature-media-shade"></div>
          </div>
          <div class="feature-detail-copy">
            <p data-feature-index>01 / 04 · 全光接入</p>
            <h3 data-feature-title>光纤延伸到业务现场</h3>
            <p data-feature-copy>
              以 FTTO 架构承载园区连接，减少中间有源节点和冗余铜缆，让网络部署更清爽，也为后续扩展预留更长生命周期。
            </p>
          </div>
        </div>
      </div>
    </section>

    <section class="product-flow" aria-labelledby="product-flow-title">
      <div class="product-section-heading" data-reveal>
        <p>A SIMPLER SIGNAL PATH</p>
        <h2 id="product-flow-title">从光纤到画面，一条更短的路径。</h2>
      </div>

      <div class="flow-diagram" data-reveal>
        <div class="flow-line" aria-hidden="true"></div>
        <button type="button" class="flow-node is-active" data-flow-node data-flow-copy="园区光网络将高带宽连接延伸到业务现场。">
          <span>01</span>
          <img src="/images/product/feature-fiber.webp" width="1600" height="900" alt="" loading="lazy" />
          <strong>FTTO 光纤</strong>
        </button>
        <button type="button" class="flow-node" data-flow-node data-flow-copy="B896-U6 汇聚网络、无线和录像能力。">
          <span>02</span>
          <img src="/images/product/huawei-optixstar-b896-u6.webp" width="2357" height="2054" alt="" loading="lazy" />
          <strong>融合网关</strong>
        </button>
        <button type="button" class="flow-node" data-flow-node data-flow-copy="摄像机与办公终端接入同一套基础设施。">
          <span>03</span>
          <img src="/images/product/feature-wifi.webp" width="1600" height="900" alt="" loading="lazy" />
          <strong>业务终端</strong>
        </button>
        <button type="button" class="flow-node" data-flow-node data-flow-copy="录像就地保存，日常查看与维护更集中。">
          <span>04</span>
          <img src="/images/product/feature-storage.webp" width="1600" height="900" alt="" loading="lazy" />
          <strong>本地存储</strong>
        </button>
      </div>
      <p class="flow-caption" data-flow-caption aria-live="polite">
        园区光网络将高带宽连接延伸到业务现场。
      </p>
    </section>

    <section class="product-facts" aria-label="产品关键信息">
      <div class="fact-card" data-reveal>
        <span>01</span>
        <img src="/images/product/feature-video.webp" width="1600" height="900" alt="" loading="lazy" />
        <strong>FTTO + NVR</strong>
        <p>网络与视频安防能力融合</p>
      </div>
      <div class="fact-card" data-reveal>
        <span>02</span>
        <img src="/images/product/feature-wifi.webp" width="1600" height="900" alt="" loading="lazy" />
        <strong>Wi-Fi 7</strong>
        <p>面向新一代无线终端</p>
      </div>
      <div class="fact-card" data-reveal>
        <span>03</span>
        <img src="/images/product/feature-storage.webp" width="1600" height="900" alt="" loading="lazy" />
        <strong>4T / 8T</strong>
        <p>两种本地存储配置</p>
      </div>
    </section>

    <p class="product-note">
      产品能力基于公开资料与设备外观信息整理；具体规格、接口及功能以实际供货配置为准。
    </p>
  </article>
</Layout>

<script>
function initProductPage() {
  const page = document.querySelector<HTMLElement>('[data-product-page]')
  if (!page || page.dataset.initialized === 'true')
    return

  page.dataset.initialized = 'true'

  const reduceMotion = document.documentElement.classList.contains('reduce-motion')
    || window.matchMedia('(prefers-reduced-motion: reduce)').matches

  const revealItems = Array.from(page.querySelectorAll<HTMLElement>('[data-reveal]'))
  if (reduceMotion || !('IntersectionObserver' in window)) {
    revealItems.forEach(item => item.classList.add('is-visible'))
  }
  else {
    const observer = new IntersectionObserver((entries) => {
      entries.forEach((entry) => {
        if (!entry.isIntersecting)
          return
        entry.target.classList.add('is-visible')
        observer.unobserve(entry.target)
      })
    }, { rootMargin: '0px 0px -10% 0px', threshold: 0.12 })
    revealItems.forEach(item => observer.observe(item))
  }

  const stage = page.querySelector<HTMLElement>('[data-product-stage]')
  const image = page.querySelector<HTMLElement>('[data-product-image]')
  if (stage && image && !reduceMotion) {
    stage.addEventListener('pointermove', (event) => {
      const rect = stage.getBoundingClientRect()
      const x = (event.clientX - rect.left) / rect.width - 0.5
      const y = (event.clientY - rect.top) / rect.height - 0.5
      stage.style.setProperty('--pointer-x', `${(x + 0.5) * 100}%`)
      stage.style.setProperty('--pointer-y', `${(y + 0.5) * 100}%`)
      image.style.transform = `perspective(900px) rotateX(${-y * 5}deg) rotateY(${x * 7}deg) translate3d(${x * 8}px, ${y * 8}px, 0)`
    })
    stage.addEventListener('pointerleave', () => {
      image.style.transform = ''
      stage.style.removeProperty('--pointer-x')
      stage.style.removeProperty('--pointer-y')
    })
  }

  const featureTabs = Array.from(page.querySelectorAll<HTMLButtonElement>('[data-feature-tab]'))
  const featureIndex = page.querySelector<HTMLElement>('[data-feature-index]')
  const featureTitle = page.querySelector<HTMLElement>('[data-feature-title]')
  const featureCopy = page.querySelector<HTMLElement>('[data-feature-copy]')
  const featureMedia = page.querySelector<HTMLElement>('[data-feature-media]')
  const featureImage = page.querySelector<HTMLImageElement>('[data-feature-image]')

  featureTabs.forEach((tab) => {
    if (tab.dataset.image)
      new Image().src = tab.dataset.image
  })

  featureTabs.forEach((tab) => {
    tab.addEventListener('click', () => {
      featureTabs.forEach((item) => {
        const active = item === tab
        item.classList.toggle('is-active', active)
        item.setAttribute('aria-selected', String(active))
      })

      if (featureIndex)
        featureIndex.textContent = `${tab.dataset.index} / 04 · ${tab.dataset.label}`
      if (featureTitle)
        featureTitle.textContent = tab.dataset.title ?? ''
      if (featureCopy)
        featureCopy.textContent = tab.dataset.copy ?? ''
      if (featureMedia) {
        featureMedia.dataset.activeFeature = tab.dataset.featureKind ?? 'fiber'
        featureMedia.classList.add('is-changing')
      }
      if (featureImage && tab.dataset.image) {
        window.setTimeout(() => {
          featureImage.src = tab.dataset.image ?? ''
          featureImage.alt = tab.dataset.imageAlt ?? ''
          featureMedia?.classList.remove('is-changing')
        }, reduceMotion ? 0 : 140)
      }
    })
  })

  const flowNodes = Array.from(page.querySelectorAll<HTMLButtonElement>('[data-flow-node]'))
  const flowCaption = page.querySelector<HTMLElement>('[data-flow-caption]')
  flowNodes.forEach((node) => {
    node.addEventListener('click', () => {
      flowNodes.forEach(item => item.classList.toggle('is-active', item === node))
      if (flowCaption)
        flowCaption.textContent = node.dataset.flowCopy ?? ''
    })
  })
}

document.addEventListener('astro:page-load', initProductPage)
initProductPage()
</script>

<style>
  .product-page {
    --product-ink: oklch(var(--un-preset-theme-colors-primary));
    --product-muted: oklch(var(--un-preset-theme-colors-secondary));
    --product-surface: var(--editorial-surface);
    --product-surface-strong: var(--editorial-surface-strong);
    --product-accent: var(--editorial-accent);
    --product-accent-strong: var(--editorial-accent-strong);
    --product-rule: var(--editorial-rule);
    overflow: clip;
    color: var(--product-ink);
  }

  .product-page :global(*) {
    box-sizing: border-box;
  }

  [data-reveal] {
    opacity: 0;
    transform: translateY(1.25rem);
    transition: opacity 700ms ease, transform 700ms cubic-bezier(0.2, 0.7, 0.2, 1);
  }

  [data-reveal].is-visible {
    opacity: 1;
    transform: translateY(0);
  }

  .product-hero {
    position: relative;
    display: grid;
    min-height: calc(100vh - 10rem);
    align-items: center;
    padding: clamp(3.5rem, 8vw, 7.5rem) 0 clamp(5rem, 9vw, 8rem);
    border-bottom: 1px solid var(--product-rule);
  }

  .product-hero::before {
    position: absolute;
    inset: 3rem -8vw auto auto;
    width: clamp(12rem, 24vw, 22rem);
    height: clamp(12rem, 24vw, 22rem);
    border: 1px solid var(--product-rule);
    border-radius: 50%;
    content: '';
    opacity: 0.6;
  }

  .product-kicker,
  .product-section-heading > p {
    margin: 0 0 1.2rem;
    color: var(--product-accent-strong);
    font-size: 0.68rem;
    font-weight: 500;
    letter-spacing: 0.18em;
  }

  .product-hero h1 {
    max-width: 15ch;
    margin: 0;
    font-size: clamp(2.45rem, 4.6vw, 4.25rem);
    font-weight: 500;
    line-height: 0.98;
    letter-spacing: -0.05em;
  }

  .product-hero h1 .product-name,
  .product-hero h1 .product-model {
    display: block;
  }

  .product-hero h1 .product-name {
    color: var(--product-ink);
  }

  .product-hero h1 .product-model {
    margin-top: 0.12em;
    color: var(--product-accent-strong);
  }

  .product-intro {
    max-width: 28rem;
    margin: 2rem 0 0;
    color: var(--product-muted);
    font-size: clamp(1.05rem, 2vw, 1.45rem);
    line-height: 1.75;
  }

  .product-tags {
    display: flex;
    flex-wrap: wrap;
    gap: 0.65rem;
    margin-top: 2rem;
  }

  .product-tags span {
    padding: 0.55rem 0.85rem;
    border: 1px solid var(--product-rule);
    border-radius: 999px;
    background: color-mix(in oklch, var(--product-surface) 76%, transparent);
    color: var(--product-muted);
    font-size: 0.72rem;
    line-height: 1;
  }

  .product-visual {
    position: relative;
    margin-top: 3rem;
  }

  .product-stage {
    --pointer-x: 50%;
    --pointer-y: 50%;
    position: relative;
    min-height: clamp(22rem, 82vw, 34rem);
    overflow: hidden;
    border: 1px solid var(--product-rule);
    border-radius: 1.25rem;
    background:
      linear-gradient(var(--product-rule) 1px, transparent 1px),
      linear-gradient(90deg, var(--product-rule) 1px, transparent 1px),
      var(--product-surface);
    background-size: 3.2rem 3.2rem;
    isolation: isolate;
  }

  .product-stage::after {
    position: absolute;
    inset: 0;
    background: radial-gradient(circle at var(--pointer-x) var(--pointer-y), color-mix(in oklch, var(--product-accent) 22%, transparent), transparent 38%);
    content: '';
    opacity: 0.75;
    pointer-events: none;
  }

  .product-glow {
    position: absolute;
    top: 18%;
    left: 50%;
    width: 62%;
    aspect-ratio: 1;
    border-radius: 50%;
    background: color-mix(in oklch, var(--product-accent) 18%, transparent);
    filter: blur(3.25rem);
    transform: translateX(-50%);
  }

  .product-stage img {
    position: absolute;
    z-index: 2;
    right: -14%;
    bottom: -9%;
    width: min(118%, 54rem);
    max-width: none;
    height: auto;
    filter: drop-shadow(0 2.2rem 2.2rem oklch(18% 0.02 330 / 0.22));
    transform-origin: 55% 70%;
    transition: transform 220ms ease-out;
    will-change: transform;
  }

  .signal-ring {
    position: absolute;
    z-index: 1;
    top: 3rem;
    right: 2rem;
    width: 9rem;
    height: 9rem;
    border: 1px solid var(--product-accent);
    border-radius: 50%;
    opacity: 0.35;
    animation: signal-pulse 3.4s ease-out infinite;
  }

  .signal-ring--two {
    animation-delay: 1.7s;
  }

  .product-stage-caption {
    position: absolute;
    z-index: 3;
    bottom: 1rem;
    left: 1rem;
    display: flex;
    gap: 0.75rem;
    align-items: center;
    margin: 0;
    color: var(--product-muted);
    font-size: 0.68rem;
    letter-spacing: 0.08em;
  }

  .product-stage-caption span {
    color: var(--product-accent-strong);
    font-variant-numeric: tabular-nums;
  }

  .product-scroll-hint {
    position: absolute;
    bottom: 1.6rem;
    left: 0;
    display: inline-flex;
    gap: 0.85rem;
    align-items: center;
    color: var(--product-muted);
    font-size: 0.68rem;
    letter-spacing: 0.1em;
  }

  .product-scroll-line {
    position: relative;
    display: block;
    width: 4.5rem;
    height: 1px;
    overflow: hidden;
    background: var(--product-rule);
  }

  .product-scroll-line::after {
    position: absolute;
    inset: 0;
    background: var(--product-accent);
    content: '';
    transform: translateX(-100%);
    animation: scroll-line 2.4s ease-in-out infinite;
  }

  .product-problem,
  .product-capabilities,
  .product-flow {
    padding: clamp(4.75rem, 9vw, 8rem) 0;
    border-bottom: 1px solid var(--product-rule);
  }

  .product-section-heading {
    max-width: 68rem;
  }

  .product-section-heading h2 {
    max-width: none;
    margin: 0;
    font-size: clamp(1.8rem, 3.8vw, 3.4rem);
    font-weight: 500;
    line-height: 1.14;
    letter-spacing: -0.04em;
    text-wrap: balance;
  }

  .product-problem-grid {
    display: grid;
    gap: 3rem;
    margin-top: clamp(3rem, 7vw, 6rem);
  }

  .product-problem-copy {
    max-width: 42rem;
    color: var(--product-muted);
    font-size: clamp(0.95rem, 1.5vw, 1.15rem);
    line-height: 1.9;
  }

  .product-problem-copy p {
    margin: 0;
  }

  .product-problem-copy p + p {
    margin-top: 1.3rem;
  }

