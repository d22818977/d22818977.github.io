          </figure>

          <div class="product-compare" aria-label="传统部署与融合部署对比">
            <div class="compare-column compare-column--before">
              <span>传统部署</span>
              <strong>4</strong>
              <p>多套设备 · 多套布线 · 多个入口</p>
            </div>
            <div class="compare-arrow" aria-hidden="true">→</div>
            <div class="compare-column compare-column--after">
              <span>融合部署</span>
              <strong>1</strong>
              <p>一台网关 · 一套架构 · 集中管理</p>
            </div>
          </div>
        </div>
